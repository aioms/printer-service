# Server Configuration
PORT=3001
NODE_ENV=development

# --- Printer (legacy printerService.js) ------------------------------------
DEFAULT_PRINTER_IP=192.168.1.220
DEFAULT_PRINTER_PORT=9100
PRINTER_TIMEOUT=5000

# --- Printer V2 (printerServiceV2.js) --------------------------------------
# Transport: tcp | usb
PRINTER_CONNECTION=tcp

# Command set: escpos | tspl | zpl
PRINTER_MODE=escpos

# ESC/POS Vietnamese encoding: tcvn3 | cp1258 | ascii
PRINTER_ENCODING=tcvn3

# USB mode: spooler (OS print queue) | libusb (requires optional `usb` npm)
PRINTER_USB_MODE=spooler

# Required when PRINTER_CONNECTION=usb and PRINTER_USB_MODE=spooler
# Name of the printer as registered in the OS (CUPS name or Windows share name).
PRINTER_USB_NAME=XP-365B

# Required when PRINTER_CONNECTION=usb and PRINTER_USB_MODE=libusb
# Vendor / Product ids in hex (default fallbacks apply if omitted).
PRINTER_USB_VENDOR_ID=0483
PRINTER_USB_PRODUCT_ID=5743

# --- Printer V2 fallback (optional) ----------------------------------------
# When primary connection preflight fails, the service automatically probes
# this fallback. Typical pairing: primary=tcp (LAN), fallback=usb (cable).
# Leave FALLBACK_PRINTER_CONNECTION blank to disable.
# Fallback inherits non-prefixed values when the FALLBACK_* variant is unset,
# so you only need to override what differs from the primary.
FALLBACK_PRINTER_CONNECTION=usb
FALLBACK_PRINTER_USB_MODE=spooler
FALLBACK_PRINTER_USB_NAME=XP-365B
# FALLBACK_PRINTER_USB_VENDOR_ID=0483
# FALLBACK_PRINTER_USB_PRODUCT_ID=5743
# FALLBACK_DEFAULT_PRINTER_IP=
# FALLBACK_DEFAULT_PRINTER_PORT=

# --- Telegram error reporting ----------------------------------------------
# Create a bot via @BotFather, then obtain chat id (e.g. via @userinfobot).
# Leave blank to disable Telegram notifications entirely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: forum topic thread id
TELEGRAM_THREAD_ID=
# Optional: prefix shown in every message
TELEGRAM_APP_NAME=AIOM Printer
# Explicit on/off override (true|false). Auto-enabled when token+chat id set.
TELEGRAM_ENABLED=true

# Security
CORS_ORIGIN=http://localhost:8100,capacitor://localhost,ionic://localhost

# Logging
LOG_LEVEL=info
LOG_FILE=logs/proxy-server.log